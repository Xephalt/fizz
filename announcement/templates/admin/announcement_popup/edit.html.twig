{% extends '@EasyAdmin/page/content.html.twig' %}

{# Titre #}
{% block content_title %}
    <h1 class="h4 mb-0">
        <i class="fa fa-pencil me-2 text-secondary"></i>
        {{ locale == 'fr' ? 'Modifier' : 'Edit' }}
        <span class="text-muted fw-normal">{{ popup.title }}</span>
    </h1>
{% endblock %}

{# Bouton retour #}
{% block page_actions %}
    <a href="{{ path('admin', { routeName: 'admin_announcement_popup_index' }) }}"
       class="btn btn-outline-secondary btn-sm">
        <i class="fa fa-arrow-left me-1"></i>
        {{ locale == 'fr' ? 'Retour' : 'Back' }}
    </a>
{% endblock %}

{% block main %}
<div class="container p-3 d-flex flex-column gap-3">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">

            {{ form_start(form, { attr: { class: 'row g-3' } }) }}

            {# ENGLISH #}
            <div class="col-12">
                <h6 class="text-uppercase text-muted fw-semibold mb-2"
                    style="font-size:.75rem; letter-spacing:.08em;">
                    <i class="fa fa-globe me-1"></i>English
                </h6>
            </div>

            <div class="col-md-8">{{ form_row(form.title) }}</div>
            <div class="col-md-4">{{ form_row(form.imageUrl) }}</div>
            <div class="col-12">{{ form_row(form.content) }}</div>

            <hr class="my-2 border-gray-300">

            {# FRENCH #}
            <div class="col-12">
                <h6 class="text-uppercase text-muted fw-semibold mb-2"
                    style="font-size:.75rem; letter-spacing:.08em;">
                    <i class="fa fa-globe me-1"></i>Français
                </h6>
            </div>

            <div class="col-md-8">{{ form_row(form.titleFr) }}</div>
            <div class="col-md-4">{{ form_row(form.imageUrlFr) }}</div>
            <div class="col-12">{{ form_row(form.contentFr) }}</div>

            <hr class="my-2 border-gray-300">

            {# AUTRES CHAMPS #}
            <div class="col-md-3">
                {{ form_row(form.priority, { value: popup.priority }) }}
            </div>

            <div class="col-md-3 d-flex align-items-center pt-3">
                {{ form_row(form.isActive) }}
            </div>

            <div class="col-md-6">
                {{ form_row(form.recurrenceSeconds) }}
            </div>

            <div class="col-12 mt-2">
                <button type="submit" class="btn btn-success px-4">
                    <i class="fa fa-save me-1"></i>
                    {{ locale == 'fr' ? 'Enregistrer' : 'Save' }}
                </button>
            </div>

            {{ form_end(form) }}

            {# FORCE RESET — form séparé car action différente #}
            <hr class="my-3 border-gray-300">
            <div class="d-flex align-items-center gap-3">
                <form method="post" action="{{ path('admin_announcement_popup_force_reset', { id: popup.id }) }}" class="mb-0">
                    <input type="hidden" name="_token" value="{{ csrf_token('force_reset_announcement_' ~ popup.id) }}">
                    <button type="submit" class="btn btn-warning px-4"
                            onclick="return confirm('{{ locale == \'fr\' ? \'Forcer le réaffichage pour tous les utilisateurs ?\' : \'Force re-display for all users?\' }}')">
                        <i class="fa fa-refresh me-1"></i>
                        {{ locale == 'fr' ? 'Forcer le réaffichage' : 'Force re-display' }}
                    </button>
                </form>
                <small class="text-muted">
                    {{ locale == 'fr'
                        ? 'Réaffiche cette popup à tous les utilisateurs, même ceux qui l\'ont déjà vue.'
                        : 'Re-displays this popup to all users, even those who already dismissed it.' }}
                    {% if popup.forcedResetAt %}
                        <br><span class="text-secondary">
                            {{ locale == 'fr' ? 'Dernier reset :' : 'Last reset:' }}
                            {{ popup.forcedResetAt|date('d/m/Y H:i') }}
                        </span>
                    {% endif %}
                </small>
            </div>

        </div>
    </div>
</div>

<style>
    .cke_notifications_area {
        display: none;
    }
</style>
{% endblock %}