{# @var ea \EasyCorp\Bundle\EasyAdminBundle\Context\AdminContext #}
{% trans_default_domain ea.i18n.translationDomain %}

<!DOCTYPE html>
<html lang="{{ ea.i18n.htmlLocale }}" dir="{{ ea.i18n.textDirection }}" data-turbo="false">

{# ================================================================
   HEAD
   ================================================================ #}
<head>

    {% block head_metas %}
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noodp, noimageindex, notranslate, nocache">
        <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
        <meta name="generator" content="EasyAdmin">
    {% endblock head_metas %}

    {% set page_title_block_output %}{% block page_title %}{{ block('content_title') }}{% endblock %}{% endset %}
    <title>{{ page_title_block_output|striptags|raw }}</title>

    {% block head_favicon %}
        <link rel="shortcut icon" href="{{ asset('/images/favicon.ico') }}">
    {% endblock %}

    {% block head_stylesheets %}
        <link rel="stylesheet" href="{{ asset('app.css', ea.assets.defaultAssetPackageName) }}">
        {{ vite_entry_link_tags('admin') }}
        <style>
            /* ---- EasyAdmin overrides ---- */
            .cke_notifications_area { display: none; }
            .submenu { padding-left: 20px !important; }
            .content { overflow: visible !important; }
            sup { top: -.5em; }

            /* ---- Sidebar layout ---- */
            .sidebar {
                display: flex;
                flex-direction: column;
            }
            #main-menu {
                flex: 1;
                overflow-y: auto;
                /* Hide scrollbar cross-browser */
                -ms-overflow-style: none;
                scrollbar-width: none;
            }
            #main-menu::-webkit-scrollbar { display: none; }

            /* ---- Sidebar footer (mobile) ---- */
            .sidemenu-footer {
                width: 500px;
                margin-left: -20px;
                margin-bottom: -15px;
            }

            /* ---- Header / logo ---- */
            #logo-container { padding: 3px; }
            #logo-container:hover {
                background: rgb(241, 240, 240);
                transition: background .3s;
            }
            .links-menu a:hover {
                background-color: #f5f5f5;
                transition: background-color .2s;
            }

            /* ---- Close sidebar button (mobile) ---- */
            .close-sidebar-button {
                position: absolute;
                top: 10px;
                right: -190px;
                background: transparent;
                border: none;
                font-size: 2rem;
                color: #666;
                cursor: pointer;
                z-index: 1001;
            }
            .close-sidebar-button:hover { color: #000; }

            /* ---- Mobile sidebar width ---- */
            body.ea-mobile-sidebar-visible .sidebar { width: 500px; }
        </style>
    {% endblock head_stylesheets %}

    {% block configured_stylesheets %}
        {{ include('@EasyAdmin/includes/_css_assets.html.twig', { assets: ea.assets.cssAssets ?? [] }, with_context=false) }}
        {{ include('@EasyAdmin/includes/_encore_link_tags.html.twig', { assets: ea.assets.webpackEncoreAssets ?? [] }, with_context=false) }}
    {% endblock %}

    {% block head_javascript %}
        <script src="{{ asset('app.js', ea.assets.defaultAssetPackageName) }}"></script>
        <script src="{{ asset('js/adminRestoreJS.js', ea.assets.defaultAssetPackageName) }}"></script>
        {{ vite_entry_script_tags('admin') }}
        {% block importmap %}
            {{ include('@EasyAdmin/includes/_importmap.html.twig', { assets: ea.assets.assetMapperAssets ?? [] }, with_context=false) }}
        {% endblock %}
    {% endblock head_javascript %}

    {% block configured_javascripts %}
        {{ include('@EasyAdmin/includes/_js_assets.html.twig', { assets: ea.assets.jsAssets ?? [] }, with_context=false) }}
        {{ include('@EasyAdmin/includes/_encore_script_tags.html.twig', { assets: ea.assets.webpackEncoreAssets ?? [] }, with_context=false) }}
    {% endblock %}

    {% block configured_head_contents %}
        {% for htmlContent in ea.assets.headContents ?? [] %}
            {{ htmlContent|raw }}
        {% endfor %}
    {% endblock %}

</head>

{# ================================================================
   BODY
   ================================================================ #}
{% block body %}
<body {% block body_attr %}{% endblock %}
      id="{% block body_id %}{% endblock %}"
      class="ea {% block body_class %}{% endblock %}"
      style="max-width:100vw; overflow:hidden;"
      data-ea-content-width="{{ ea.crud.contentWidth ?? ea.dashboardContentWidth ?? 'normal' }}"
      data-ea-sidebar-width="{{ ea.crud.sidebarWidth ?? ea.dashboardSidebarWidth ?? 'normal' }}"
      data-ea-dark-scheme-is-enabled="{{ ea.dashboardHasDarkModeEnabled ? 'true' : 'false' }}"
      data-ea-default-color-scheme="{{ ea.dashboardDefaultColorScheme }}"
      data-ea-icon-set="{{ ea.assets.iconSet }}"
      data-ea-icon-prefix="{{ ea.assets.defaultIconPrefix }}"
>

    {% block javascript_page_layout %}
        <script src="{{ asset('page-layout.js', ea.assets.defaultAssetPackageName) }}"></script>
    {% endblock %}
    {% block javascript_page_color_scheme %}
        <script src="{{ asset('page-color-scheme.js', ea.assets.defaultAssetPackageName) }}"></script>
    {% endblock %}

    {% block wrapper_wrapper %}

        {# ---- Flash messages ---- #}
        {% block flash_messages %}
            {{ include(ea.templatePath('flash_messages')) }}
        {% endblock %}

        {# ================================================================
           COMPUTED VARIABLES (user avatar, dropdown menus)
           ================================================================ #}

        {# User avatar #}
        {% set user_menu_avatar %}
            {% if ea.userMenu.avatarUrl is null %}
                <span class="user-avatar"><twig:ea:Icon name="internal:user" /></span>
            {% else %}
                <img class="user-avatar" src="{{ ea.userMenu.avatarUrl }}">
            {% endif %}
        {% endset %}

        {% set impersonator_permission = constant('Symfony\\Component\\Security\\Core\\Authorization\\Voter\\AuthenticatedVoter::IS_IMPERSONATOR') is defined
            ? 'IS_IMPERSONATOR'
            : 'ROLE_PREVIOUS_ADMIN' %}

        {# User dropdown #}
        {% set user_menu_dropdown %}
            <ul class="dropdown-menu dropdown-menu-end" style="border-radius:7px;">
                <li class="dropdown-user-details">
                    <div>{{ user_menu_avatar }}</div>
                    <div>
                        <span class="user-label">{{ 'user.logged_in_as'|trans(domain='EasyAdminBundle') }}</span>
                        <span class="user-name">
                            {{ ea.user is null ? 'user.anonymous'|trans(domain='EasyAdminBundle') : ea.userMenu.name }}
                        </span>
                    </div>
                </li>

                {% block user_menu %}
                    {% for item in ea.userMenu.items %}
                        <li>
                            {% if item.isMenuSection and not loop.first %}
                                <hr class="dropdown-divider">
                            {% elseif not item.isMenuSection %}
                                <a href="{{ item.linkUrl }}"
                                   class="dropdown-item user-action {{ item.cssClass }}"
                                   target="{{ item.linkTarget }}"
                                   rel="{{ item.linkRel }}"
                                   referrerpolicy="origin-when-cross-origin">
                                    {% if item.icon is not empty %}<twig:ea:Icon name="{{ item.icon }}" />{% endif %}
                                    {{ item.label|trans }}
                                </a>
                            {% endif %}
                        </li>
                    {% endfor %}
                {% endblock user_menu %}
            </ul>
        {% endset %}

        {# Settings (locale + dark mode) dropdown #}
        {% set settings_dropdown %}
            {% if ea.dashboardLocales or ea.dashboardHasDarkModeEnabled %}
                <div class="dropdown dropdown-settings d-flex align-items-center" style="border-radius:7px;">
                    <a class="text-black px-4 d-flex align-items-center justify-content-center"
                       type="button"
                       data-bs-toggle="dropdown"
                       data-bs-offset="0,5"
                       aria-expanded="false">
                        {% if locale == 'fr' %}
                            <span class="flex px-1"><twig:ea:Flag countryCode="FR" height="17" /></span>
                        {% else %}
                            <span class="flex px-1"><twig:ea:Flag countryCode="GB" height="17" /></span>
                        {% endif %}
                        {{ "frontend.selectedLanguageShort"|trans }}
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end" style="border-radius:7px;">
                        {% if ea.dashboardLocales %}
                            {% for localeDto in ea.dashboardLocales %}
                                <li>
                                    <a href="{{ ea_url().set('locale', localeDto.locale) }}"
                                       class="dropdown-item{% if app.request.locale == localeDto.locale %} active{% endif %}">
                                        {% if localeDto.icon %}<twig:ea:Icon name="{{ localeDto.icon }}" />{% endif %}
                                        {{ localeDto.name }}
                                    </a>
                                </li>
                            {% endfor %}
                        {% endif %}

                        {% if ea.dashboardHasDarkModeEnabled %}
                            {% if ea.dashboardLocales %}<div class="dropdown-divider"></div>{% endif %}
                            <li class="dropdown-header dropdown-appearance-label">
                                {{ 'settings.appearance.label'|trans(domain='EasyAdminBundle') }}
                            </li>
                            <li>
                                <a href="#" class="dropdown-item dropdown-appearance-item" data-ea-color-scheme="light">
                                    <twig:ea:Icon name="internal:sun" />
                                    {{ 'settings.appearance.light'|trans(domain='EasyAdminBundle') }}
                                </a>
                            </li>
                            <li>
                                <a href="#" class="dropdown-item dropdown-appearance-item" data-ea-color-scheme="dark">
                                    <twig:ea:Icon name="internal:moon" />
                                    {{ 'settings.appearance.dark'|trans(domain='EasyAdminBundle') }}
                                </a>
                            </li>
                            <li>
                                <a href="#" class="dropdown-item dropdown-appearance-item active" data-ea-color-scheme="auto">
                                    <twig:ea:Icon name="internal:desktop" />
                                    {{ 'settings.appearance.auto'|trans(domain='EasyAdminBundle') }}
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            {% endif %}
        {% endset %}

        {# ================================================================
           PAGE SHELL : header | sidebar + content | footer
           ================================================================ #}
        <div style="min-block-size:unset !important; display:grid !important; grid-template-rows:auto 1fr auto; height:100vh;">

            {# ---- HEADER ---- #}
            {% block header_custom_menu_wrapper %}
                <header class="main-header d-flex">
                    {% block header %}
                        <nav class="navbar d-flex justify-content-between w-100 px-2 ps-1 shadow align-items-center"
                             role="navigation">
                            {% block header_navbar %}

                                {# Mobile: hamburger #}
                                <div class="hide-on-large">
                                    {% block responsive_header %}
                                        <button id="navigation-toggler" class="ms-1 p-2" type="button" aria-label="Toggle navigation">
                                            <twig:ea:Icon name="internal:menu-bars" />
                                        </button>
                                    {% endblock %}
                                </div>

                                {# Desktop: logo #}
                                <div class="hide-on-small d-flex align-items-center" style="border-radius:7px;" id="logo-container">
                                    {% block header_logo %}
                                        <a class="logo d-flex align-items-center"
                                           style="padding-left:2px;"
                                           title="{{ ea.dashboardTitle|striptags }}"
                                           href="{{ path(ea.dashboardRouteName) }}">
                                            {{ ea.dashboardTitle|raw }}
                                            <div class="border mx-1 me-2" style="padding:10px 0;"></div>
                                            <span class="font-open text-dark ps-1" style="font-size:14px; padding-bottom:3px;">COMMS GPT</span>
                                        </a>
                                    {% endblock %}
                                </div>

                                {# Mobile: app name #}
                                <div class="hide-on-large d-flex align-items-center" style="border-radius:7px;">
                                    <span class="font-open text-dark ps-1" style="font-size:14px; padding-bottom:3px;">COMMS GPT</span>
                                </div>

                            {% endblock header_navbar %}

                            {# Nav links + user menu #}
                            <div class="d-flex w-100 links-menu">

                                {# Desktop nav links #}
                                <nav class="hide-on-small">
                                    <ul class="d-flex justify-content-center align-items-center overflow-hidden font-open list-unstyled mb-0 me-0"
                                        style="font-size:13px;">

                                        <li class="text-dark h-100 d-flex align-items-center pr-3" style="color:rgb(94 94 94);">
                                            COMMS GPT
                                        </li>

                                        <li class="text-dark h-100 p-3 px-3 d-flex align-items-center border-top border-start border-end border-success"
                                            style="color:rgb(94 94 94); box-shadow:inset 0 -3px 0 #008550;">
                                            <a class="text-dark p-3 h-100 d-flex align-items-center"
                                               style="color:rgb(94 94 94);"
                                               href="{{ path('app_chat') }}">Admin</a>
                                        </li>

                                        {% for page in pages|sort((a, b) => a.orderPage <=> b.orderPage) %}
                                            {% if "header" in page.location %}
                                                <li>
                                                    <a class="text-dark p-3 h-100 d-flex align-items-center"
                                                       style="color:rgb(94 94 94);"
                                                       href="/{{ page.slug }}">
                                                        {{ locale == 'fr' ? page.titleFr : page.title }}
                                                    </a>
                                                </li>
                                            {% endif %}
                                        {% endfor %}

                                        <li>
                                            <a class="text-dark h-100 d-flex align-items-center p-3"
                                               style="color:rgb(94 94 94);"
                                               href="/prompt-gallery/favorites">
                                                {{ locale == 'fr' ? 'Galerie de requêtes' : 'Prompt gallery' }}
                                            </a>
                                        </li>

                                    </ul>
                                </nav>

                                {# Settings dropdown (desktop) #}
                                {% block settings_dropdown_wrapper %}
                                    <div class="hide-on-small d-flex">{{ settings_dropdown }}</div>
                                {% endblock %}

                                {# User avatar dropdown #}
                                <div class="navbar-custom-menu h-100 d-flex align-items-center me-3">
                                    {% block header_custom_menu %}
                                        <div class="dropdown user-menu-wrapper {{ is_granted(impersonator_permission) ? 'user-is-impersonated' }}">
                                            <a type="button"
                                               class="user-dropdown d-inline-flex w-full justify-center gap-x-1.5 rounded-circle p-3 text-sm font-semibold text-gray-900 shadow-sm"
                                               style="background-color:#7BAFFF !important;"
                                               data-bs-toggle="dropdown"
                                               data-bs-offset="0,5"
                                               aria-expanded="false">
                                                {% if ea.userMenu.isNameDisplayed %}
                                                    <span class="position-absolute text-black fw-bold"
                                                          style="top:50%; left:50%; transform:translate(-50%,-50%);">
                                                        {{ app.user.name|first|upper }}
                                                    </span>
                                                {% endif %}
                                            </a>
                                            {{ user_menu_dropdown }}
                                        </div>
                                    {% endblock %}
                                </div>

                            </div>{# /links-menu #}
                        </nav>
                    {% endblock header %}
                </header>
            {% endblock header_custom_menu_wrapper %}

            {# ---- SIDEBAR + MAIN CONTENT ---- #}
            <div class="d-flex h-100 pe-0" style="overflow-y:auto;">
                {% block wrapper %}

                    {# Sidebar #}
                    <div class="sidebar-wrapper">
                        <aside class="sidebar" style="min-block-size:unset !important;">
                            {% block sidebar %}

                                {% block main_menu_wrapper %}
                                    {{ include(ea.templatePath('main_menu')) }}
                                {% endblock %}

                                {# Mobile sidebar footer (lang switch + nav links) #}
                                {% set currentUrl = app.request.requestUri %}
                                {% set urlBase = currentUrl starts with '/en' ? currentUrl|replace({'/en':''}) : currentUrl %}

                                <footer class="sidemenu-footer py-2 text-white bg-dark hide-on-large">

                                    {# Nav links #}
                                    <div class="d-flex justify-content-center">
                                        <nav class="d-flex justify-content-around">
                                            <ul class="d-flex overflow-hidden font-open list-unstyled mb-0 me-0" style="font-size:13px;">
                                                <li class="d-flex align-items-center">
                                                    <a class="text-white d-flex px-3" href="{{ path('app_chat') }}">COMMS GPT</a>
                                                </li>
                                                {% for page in pages|sort((a, b) => a.orderPage <=> b.orderPage) %}
                                                    {% if "header" in page.location %}
                                                        <li class="d-flex align-items-center">
                                                            <a class="text-white px-3 d-flex" href="/{{ page.slug }}">
                                                                {{ locale == 'fr' ? page.titleFr : page.title }}
                                                            </a>
                                                        </li>
                                                    {% endif %}
                                                {% endfor %}
                                                <li class="d-flex align-items-center">
                                                    <a class="text-white px-3 d-flex" href="/prompt-gallery/favorites">
                                                        {{ locale == 'fr' ? 'Galerie de requêtes' : 'Prompt gallery' }}
                                                    </a>
                                                </li>
                                            </ul>
                                        </nav>
                                    </div>

                                    {# Language switcher #}
                                    <div class="flex flex-row text-center p-2">
                                        <span class="text-sm text-white p-1">Langue :</span>
                                        {% for lang, label in { fr: 'FR', en: 'EN' } %}
                                            {% set isActive = app.request.locale == lang %}
                                            <a class="text-sm text-white px-1"
                                               href="{{ lang == 'en' ? '/en' ~ urlBase : urlBase }}"
                                               style="padding:4px 10px; border-radius:4px; text-decoration:none; {{ isActive ? 'background-color:white;' }}">
                                                <span style="{{ isActive ? 'color:black; font-weight:bold;' : 'color:white;' }}">{{ label }}</span>
                                            </a>
                                        {% endfor %}
                                    </div>

                                    <hr class="my-1">

                                    {# Footer links #}
                                    <div class="d-flex justify-content-around text-center py-1 px-3 text-sm">
                                        <ul class="d-flex gap-5 mb-0 list-unstyled">
                                            {% for sidebarPage in sidebarPages|sort((a, b) => a.orderPage <=> b.orderPage) %}
                                                {% if "footer" in sidebarPage.location and sidebarPage.childrenPages[0] is defined %}
                                                    <li>
                                                        <a class="text-white hover:underline"
                                                           style="font-size:14px; font-weight:300;"
                                                           href="/{{ sidebarPage.childrenPages[0].slug }}">
                                                            {{ locale == 'fr' ? sidebarPage.titleFr : sidebarPage.title }}
                                                        </a>
                                                    </li>
                                                {% endif %}
                                            {% endfor %}
                                            {% for page in pages|sort((a, b) => a.orderPage <=> b.orderPage) %}
                                                {% if "footer" in page.location %}
                                                    <li>
                                                        <a class="text-white hover:underline" href="/{{ page.slug }}">
                                                            {{ locale == 'fr' ? page.titleFr : page.title }}
                                                        </a>
                                                    </li>
                                                {% endif %}
                                            {% endfor %}
                                        </ul>
                                    </div>

                                    <hr class="my-1">

                                    <div class="col text-center pt-2">
                                        <span>Powered by DataLab & AI - COMMS GPT</span>
                                    </div>

                                </footer>

                            {% endblock sidebar %}

                            <div id="sidebar-resizer-handler"
                                 class="resizer-handler resizer-handler-left"
                                 style="min-block-size:unset !important;"></div>
                        </aside>
                    </div>

                    {# ---- MAIN CONTENT AREA ---- #}
                    <section class="main-content w-100" style="overflow-y:auto;">

                        {# Search bar (only when CRUD search is enabled) #}
                        {% set has_search = ea.crud is not null and ea.crud.isSearchEnabled %}
                        {% if has_search %}
                            <aside class="content-top ea-search-enabled">
                                {% block content_top_header %}
                                    {% block search_wrapper %}
                                        <div class="content-search">
                                            {% block search %}
                                                {% set formActionUrl = null %}
                                                {% if ea.usePrettyUrls %}
                                                    {% set formActionUrl = ea_url()
                                                        .setController(ea.request.attributes.get('crudControllerFqcn'))
                                                        .setAction('index')
                                                        .set('page', 1) %}
                                                {% endif %}

                                                <form class="form-action-search" method="get"
                                                      {% if formActionUrl %}action="{{ formActionUrl }}"{% endif %}>
                                                    {% block search_form %}
                                                        {% block search_form_for_filters %}
                                                            {% for field, fieldValue in ea.search.appliedFilters %}
                                                                {% if fieldValue is iterable %}
                                                                    {% for key, value in fieldValue %}
                                                                        {% if value is iterable %}
                                                                            {% for index, iterValue in value %}
                                                                                {% if iterValue is iterable %}
                                                                                    {% for subIndex, subIterValue in iterValue %}
                                                                                        <input type="hidden" name="filters[{{ field }}][{{ key }}][{{ index }}][{{ subIndex }}]" value="{{ subIterValue }}">
                                                                                    {% endfor %}
                                                                                {% else %}
                                                                                    <input type="hidden" name="filters[{{ field }}][{{ key }}][{{ index }}]" value="{{ iterValue }}">
                                                                                {% endif %}
                                                                            {% endfor %}
                                                                        {% else %}
                                                                            <input type="hidden" name="filters[{{ field }}][{{ key }}]" value="{{ value }}">
                                                                        {% endif %}
                                                                    {% endfor %}
                                                                {% else %}
                                                                    <input type="hidden" name="filters[{{ field }}]" value="{{ fieldValue }}">
                                                                {% endif %}
                                                            {% endfor %}
                                                        {% endblock %}

                                                        {% if not ea.usePrettyUrls %}
                                                            <input type="hidden" name="crudAction" value="index">
                                                            <input type="hidden" name="crudControllerFqcn" value="{{ ea.request.query.get('crudControllerFqcn') }}">
                                                            <input type="hidden" name="page" value="1">
                                                        {% endif %}

                                                        <div class="form-group">
                                                            <div class="form-widget">
                                                                <twig:ea:Icon name="internal:search" class="content-search-icon" />
                                                                <label class="content-search-label" data-value="{{ app.request.get('query') }}">
                                                                    <input class="form-control {{ app.request.get('query') is null ? 'is-blank' }}"
                                                                           type="search"
                                                                           name="query"
                                                                           value="{{ app.request.get('query') ?? '' }}"
                                                                           placeholder="{{ 'action.search'|trans(ea.i18n.translationParameters, 'EasyAdminBundle') }}"
                                                                           spellcheck="false"
                                                                           autocorrect="off"
                                                                           onInput="this.parentNode.dataset.value=this.value"
                                                                           {% if ea.crud.currentAction == 'index' and ea.crud.autofocusSearch %}autofocus{% endif %}>
                                                                </label>
                                                                {% if app.request.get('query') %}
                                                                    {% set search_reset_url = ea.usePrettyUrls
                                                                        ? ea_url().unset('query').setController(ea.request.attributes.get('crudControllerFqcn')).setAction('index').set('page', 1)
                                                                        : ea_url().unset('query') %}
                                                                    <a href="{{ search_reset_url }}" class="content-search-reset">
                                                                        <twig:ea:Icon name="internal:xmark" />
                                                                    </a>
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    {% endblock search_form %}
                                                </form>
                                            {% endblock search %}
                                        </div>
                                    {% endblock search_wrapper %}
                                {% endblock content_top_header %}
                            </aside>
                        {% endif %}

                        <div class="content-wrapper">
                            {% block content %}
                                <article class="content">

                                    {% block content_header_wrapper %}
                                        {% set has_help_message = (ea.crud.helpMessage ?? '') is not empty %}
                                        <section class="content-header">
                                            {% block content_header %}
                                                <div class="content-header-title">
                                                    <h1 class="title">
                                                        {% block content_title %}{% endblock %}
                                                        {% block content_help %}
                                                            {% if has_help_message %}
                                                                <a tabindex="0"
                                                                   class="content-header-help"
                                                                   data-bs-toggle="popover"
                                                                   data-bs-custom-class="ea-content-help-popover"
                                                                   data-bs-animation="true"
                                                                   data-bs-html="true"
                                                                   data-bs-placement="bottom"
                                                                   data-bs-trigger="focus"
                                                                   data-bs-content="{{ ea.crud.helpMessage|trans|html_attr }}">
                                                                    <twig:ea:Icon name="internal:circle-info" />
                                                                </a>
                                                            {% endif %}
                                                        {% endblock %}
                                                    </h1>
                                                </div>
                                                {% block page_actions_wrapper %}
                                                    <div class="page-actions">{% block page_actions %}{% endblock %}</div>
                                                {% endblock %}
                                            {% endblock content_header %}
                                        </section>
                                    {% endblock content_header_wrapper %}

                                    <section id="main" class="content-body">
                                        {% block main %}{% endblock %}
                                    </section>

                                    {% block content_footer_wrapper %}
                                        {% set content_footer = block('content_footer') is defined ? block('content_footer') : '' %}
                                        {% if content_footer is not empty %}
                                            <section class="content-footer">{{ content_footer }}</section>
                                        {% endif %}
                                    {% endblock %}

                                </article>
                            {% endblock content %}

                            <div id="content-resizer-handler"
                                 class="resizer-handler resizer-handler-right"
                                 style="min-block-size:unset !important;"></div>
                        </div>
                    </section>

                {% endblock wrapper %}
            </div>

            {# ---- FOOTER (desktop) ---- #}
            <footer class="bg-black d-flex justify-content-between align-items-center gap-9 font-open py-1 hide-on-small">
                <div class="d-flex justify-content-center py-1">
                    <span class="text-white font-open" style="font-size:12px; font-weight:300;">
                        Powered by DataLab & AI - COMMS GPT
                    </span>
                </div>

                <ul class="d-flex gap-5 align-items-center mb-0 list-unstyled font-tix">
                    {% for sidebarPage in sidebarPages|sort((a, b) => a.orderPage <=> b.orderPage) %}
                        {% if "footer" in sidebarPage.location and sidebarPage.childrenPages[0] is defined %}
                            <li>
                                <a class="text-white hover:underline"
                                   style="font-size:14px; font-weight:300;"
                                   href="/{{ sidebarPage.childrenPages[0].slug }}">
                                    {{ locale == 'fr' ? sidebarPage.titleFr : sidebarPage.title }}
                                </a>
                            </li>
                        {% endif %}
                    {% endfor %}
                    {% for page in pages %}
                        {% if "footer" in page.location %}
                            <li>
                                <a class="text-white hover:underline" href="/{{ page.slug }}">
                                    {{ locale == 'fr' ? page.titleFr : page.title }}
                                </a>
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
            </footer>

        </div>{# /page-shell grid #}

    {% endblock wrapper_wrapper %}

    {% block body_javascript %}{% endblock %}

    {% block configured_body_contents %}
        {% for htmlContent in ea.assets.bodyContents ?? [] %}
            {{ htmlContent|raw }}
        {% endfor %}
    {% endblock %}

</body>
{% endblock body %}

</html>
